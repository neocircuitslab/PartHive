{
  "$schema": "https://go.kicad.org/api/schemas/v1",
  "identifier": "com.github.neocircuitslab.parthive",
  "name": "PartHive",
  "description": "Import EasyEDA/JLCPCB (LCSC) parts into a KiCad library",
  "runtime": {
    "type": "python",
    "version": "3"
  },
  "actions": [
    {
      "identifier": "parthive-import",
      "name": "PartHive",
      "description": "Import EasyEDA/JLCPCB (LCSC) components (symbol, footprint, 3D model)",
      "show-button": true,
      "scopes": [
        "schematic",
        "pcb"
      ],
      "entrypoint": "parthive_action.py",
      "icons-light": [
        "icon.png"
      ],
      "icons-dark": [
        "icon.png"
      ]
    }
  ]
}
